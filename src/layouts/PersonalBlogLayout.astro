---
import type { PersonalBlogPerson } from "../data/personal-blogs";

export interface Props {
    person: PersonalBlogPerson;
    title: string;
    description?: string;
    pubDate?: Date;
    type?: "website" | "article";
}

const { person, title, description = person.tagline, pubDate, type = "website" } = Astro.props;

const siteBase = "https://elhellal.com";
const canonicalUrl = new URL(Astro.url.pathname, siteBase).toString();
const homeHref = `/${person.slug}`;

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: person.nameAr,
    description: person.bio,
    url: new URL(homeHref, siteBase).toString(),
};

const articleSchema = type === "article" && pubDate ? {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description,
    datePublished: pubDate.toISOString(),
    author: { "@type": "Person", name: person.nameAr, url: new URL(homeHref, siteBase).toString() },
    mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
} : null;
---

<!doctype html>
<html lang="ar" dir="rtl" style={`--accent: ${person.accent}`}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={person.nameAr} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={person.nameAr} />
    <meta property="og:locale" content="ar" />
    {type === "article" && pubDate && (
        <meta property="article:published_time" content={pubDate.toISOString()} />
    )}

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
</head>
<body>
    <slot />
</body>
</html>

<style is:global>
    html[dir="rtl"] body {
        font-family: 'Cairo', sans-serif;
        background-color: #eeebe4;
        color: #1c1b1a;
        margin: 0;
    }
    a { color: inherit; }
</style>
