---
import type { PersonalBlogPerson } from "../../data/personal-blogs";

export interface Props { person: PersonalBlogPerson };
const { person } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="pb-footer">
    <p class="pb-bio">{person.bio}</p>
    <p class="pb-copyright">© {year} {person.nameAr} · جزء من <a href="https://elhellal.com/">elhellal.com</a></p>
</footer>

<style>
    .pb-footer {
        max-width: 700px;
        margin: 4rem auto 0;
        padding: 2rem 1.5rem 3rem;
        border-top: 1px solid #d0cdc6;
        text-align: center;
    }
    .pb-bio {
        font-size: 0.9rem;
        line-height: 1.9;
        color: #55524b;
        margin: 0 0 1rem;
    }
    .pb-copyright {
        font-size: 0.8rem;
        color: #8a857b;
        margin: 0;
    }
    .pb-copyright a { text-decoration: underline; }
</style>
