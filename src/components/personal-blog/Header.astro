---
import type { PersonalBlogPerson } from "../../data/personal-blogs";

export interface Props { person: PersonalBlogPerson };
const { person } = Astro.props;
---

<header class="pb-header">
    <a href="https://elhellal.com/" class="pb-back">← elhellal.com</a>
    <a href={`/${person.slug}`} class="pb-masthead-link">
        <p class="pb-masthead-name">{person.nameAr}</p>
    </a>
    <div class="pb-subtitle-row">
        <span class="pb-rule"></span>
        <span class="pb-tagline">{person.tagline}</span>
        <span class="pb-rule"></span>
    </div>
</header>

<style define:vars={{ accent: person.accent }}>
    .pb-header {
        max-width: 900px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 2rem;
        text-align: center;
        position: relative;
    }
    .pb-back {
        position: absolute;
        top: 1rem;
        right: 1.5rem;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.05em;
        color: #8a857b;
        text-decoration: none;
        direction: ltr;
    }
    .pb-back:hover { color: #1c1b1a; }
    .pb-masthead-link { text-decoration: none; }
    .pb-masthead-name {
        font-weight: 800;
        color: #1c1b1a;
        letter-spacing: -0.01em;
        font-size: clamp(2rem, 7vw, 3.5rem);
        margin: 0.5rem 0 0;
    }
    .pb-subtitle-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.1rem;
        margin-top: 1rem;
        padding: 0 1.5rem;
    }
    .pb-rule {
        height: 1px;
        flex: 1;
        max-width: 70px;
        background: #cfcabf;
    }
    .pb-tagline {
        font-size: 11px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 600;
    }
</style>
