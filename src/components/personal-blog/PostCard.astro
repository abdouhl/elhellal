---
import type { PersonalBlogPerson } from "../../data/personal-blogs";

export interface Props {
    person: PersonalBlogPerson;
    title: string;
    description: string;
    pubDate: Date;
    slug: string;
    thumb?: string;
}
const { person, title, description, pubDate, slug, thumb } = Astro.props;
const dateAr = new Intl.DateTimeFormat("ar", { year: "numeric", month: "long", day: "numeric" }).format(pubDate);
---

<li class="pb-card">
    {thumb && (
        <a href={`/${person.slug}/${slug}`} class="pb-thumb-link">
            <img src={thumb} alt={title} loading="lazy" class="pb-thumb" />
        </a>
    )}
    <div class="pb-card-body">
        <p class="pb-date">{dateAr}</p>
        <h2 class="pb-title"><a href={`/${person.slug}/${slug}`}>{title}</a></h2>
        <p class="pb-desc">{description}</p>
        <a href={`/${person.slug}/${slug}`} class="pb-readmore" style={`color:${person.accent}`}>اقرأ المزيد ←</a>
    </div>
</li>

<style>
    .pb-card {
        display: flex;
        gap: 1.5rem;
        align-items: flex-start;
        padding: 1.75rem 0;
        border-bottom: 1px solid #d0cdc6;
    }
    .pb-thumb-link { flex-shrink: 0; display: none; }
    .pb-thumb { width: 180px; height: 120px; object-fit: cover; }
    .pb-card-body { flex: 1; min-width: 0; }
    .pb-date { font-size: 0.75rem; color: #8a857b; margin: 0 0 0.5rem; }
    .pb-title { font-size: 1.3rem; font-weight: 700; line-height: 1.4; margin: 0 0 0.5rem; color: #1c1b1a; }
    .pb-title a { text-decoration: none; }
    .pb-title a:hover { text-decoration: underline; }
    .pb-desc { font-size: 0.9rem; line-height: 1.8; color: #55524b; margin: 0 0 0.75rem; }
    .pb-readmore { font-size: 0.75rem; font-weight: 700; text-decoration: none; }
    @media (min-width: 640px) {
        .pb-thumb-link { display: block; }
    }
</style>
