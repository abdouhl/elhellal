---
export interface Props {
    /** Ad unit slot ID from the AdSense dashboard */
    slot: string;
    format?: string;
    /** e.g. "in-article" — set together with format="fluid" for native in-article units */
    layout?: string;
    /** data-ad-layout-key value for fluid in-feed units */
    layoutKey?: string;
    className?: string;
}

const { slot, format = "auto", layout, layoutKey, className = "" } = Astro.props;
const insStyle = layout === "in-article" ? "display:block; text-align:center;" : "display:block";
---

<div class={`ad-unit ${className}`} aria-label="إعلان">
    <span class="ad-unit-label">إعلان</span>
    <ins
        class="adsbygoogle"
        style={insStyle}
        data-ad-client="ca-pub-3610150616518651"
        data-ad-slot={slot}
        data-ad-format={format}
        data-ad-layout={layout}
        data-ad-layout-key={layoutKey}
        data-full-width-responsive={layout ? undefined : "true"}></ins>
</div>

<style>
    .ad-unit {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-height: 90px;
    }

    .ad-unit-label {
        font-family: var(--monospace);
        font-size: 10px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.3);
    }
</style>
