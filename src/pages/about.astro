---
import Layout from "../layouts/Layout.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
const breadcrumbs = [
    { name: "الرئيسية", url: "https://elhellal.com" },
    { name: "حول الموقع", url: "https://elhellal.com/about" },
];
---

<Layout
    site="الهلال"
    title="حول الموقع"
    tagline="القصة وراء دليل أفضل المقالات العربية على الإنترنت"
    pageTitle="حول الهلال"
    pageDescription="الهلال دليل منتقى لأفضل المقالات العربية على الإنترنت. اعرف المزيد عن مهمتنا وطريقة الانتقاء والشخص وراء المشروع."
    canonicalUrl="https://elhellal.com/about"
    ogTitle="حول الهلال — دليل المقالات العربية"
    ogDescription="اعرف المزيد عن الهلال، وطريقة انتقاء المقالات، ومهمتنا في إبراز أفضل الكتابة العربية من مصادر متعددة."
    ogType="website"
    ogUrl="https://elhellal.com/about"
    ogSiteName="الهلال"
>
    <BreadcrumbSchema items={breadcrumbs} />

    <main id="main-content" class="container">
        <div class="legal-content-wrapper">
            <header class="legal-header">
                <h1 class="nu-c-h5 nu-u-text--primary">حول الهلال</h1>
                <p class="last-updated">دليل منتقى لأفضل المقالات العربية على الإنترنت</p>
            </header>

            <article class="nu-u-text--secondary" itemscope itemtype="https://schema.org/AboutPage">

                <h2 class="nu-c-h6 nu-u-text--primary">ما هو الهلال؟</h2>
                <p>
                    <strong class="nu-u-text--primary">الهلال</strong> دليل منتقى لأفضل المقالات العربية على الإنترنت —
                    من Substack والمدونات الشخصية والنشرات البريدية. تحتضن هذه المصادر بعضاً من أعمق الكتابات العربية اليوم
                    — لكنها غالباً ما تكون مدفونة وسط آلاف المنشورات المتفرقة. نحن نُبرزها لك.
                </p>
                <p>
                    نفهرس المقالات والتحليلات والدراسات المعمّقة عبر تصنيفات متنوعة كالتقنية والاقتصاد
                    والعلوم والثقافة والأعمال — كتبها نخبة من أبرز الكُتّاب العرب.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">مهمتنا</h2>
                <p>
                    الكتابة الجيدة تستحق أن تُقرأ. مهمتنا بسيطة: تسهيل اكتشاف المحتوى العربي عالي الجودة
                    من أي مصدر، بصرف النظر عن عدد المتابعين أو الخوارزميات. الجودة قبل الانتشار.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">كيف ننتقي المحتوى؟</h2>
                <p>
                    كل مقالة في الدليل تمر بمراجعة يدوية قبل إضافتها. نبحث عن:
                </p>
                <ul>
                    <li>أفكار أصيلة وتحليل حقيقي</li>
                    <li>العمق — مقالات تتجاوز السطحية</li>
                    <li>كتابة منظّمة تستحق وقتك</li>
                    <li>الصلة بمجالات ومواضيع متنوعة</li>
                </ul>
                <p>
                    لا نلاحق المحتوى الرائج. نبحث عن المقالات التي ستظل تستحق القراءة بعد أشهر.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">من بنى هذا؟</h2>
                <p>
                    الهلال من بناء وصيانة
                    <a href="https://elhellal.com/" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">عبدالرحمن هلال</a>
                    (<a href="https://twitter.com/abdou_hll" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">@abdou_hll</a>)
                    — مطوّر ومنتقٍ شغوف بإبراز الكتابة العربية الجيدة على الويب.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">اقترح مقالة</h2>
                <p>
                    وجدت مقالة عربية رائعة تستحق الاهتمام؟ نودّ معرفتها.
                    تواصل مع
                    <a href="https://twitter.com/abdou_hll" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">@abdou_hll</a>
                    على X باقتراحك.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">الإعلانات والدعم</h2>
                <p>
                    الهلال مجاني للاستخدام. يُدعم المشروع من خلال الإعلانات والروابط التابعة.
                    راجع <a href="/terms" class="nu-u-link--subtle">شروط الاستخدام</a>
                    و<a href="/privacy" class="nu-u-link--subtle">سياسة الخصوصية</a> للتفاصيل الكاملة.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">تواصل معنا</h2>
                <p>
                    للأسئلة أو الاقتراحات أو الشراكات، تواصل مع
                    <a href="https://twitter.com/abdou_hll" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">@abdou_hll</a>
                    على X، أو زر <a href="https://elhellal.com/" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">elhellal.com</a>.
                </p>
            </article>
        </div>
    </main>
</Layout>
