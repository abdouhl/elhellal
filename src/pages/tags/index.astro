---
import Layout from "../../layouts/Layout.astro";
import BreadcrumbSchema from "../../components/schema/BreadcrumbSchema.astro";
import { getQualifyingTags } from "../../utils/tags";

const tags = getQualifyingTags();

const breadcrumbs = [
  { name: "الرئيسية", url: "https://elhellal.com" },
  { name: "الوسوم" },
];
---

<Layout
  site="الهلال - الوسوم"
  title="الهلال"
  tagline="دليل منتقى لأفضل المقالات العربية على الإنترنت"
  pageTitle="تصفح المقالات حسب الوسم | الهلال"
  pageDescription="تصفح جميع الوسوم والمواضيع المتكررة في مقالات الهلال، من علم النفس إلى السياسة والتنمية الذاتية."
  canonicalUrl="https://elhellal.com/tags/"
>
  <BreadcrumbSchema items={breadcrumbs} />

  <main id="main-content" class="tags-page">
    <nav class="breadcrumb" aria-label="مسار التنقل">
      <a href="/">الرئيسية</a>
      <span aria-hidden="true">›</span>
      <span>الوسوم</span>
    </nav>

    <header class="tags-header">
      <h1>تصفح حسب الوسم</h1>
      <p>{tags.length} وسماً يجمع مقالات متقاربة الموضوع</p>
    </header>

    <ul role="list" class="tag-cloud">
      {tags.map((tag) => (
        <li>
          <a href={`/tags/${tag.slug}`} class="tag-pill">
            {tag.label}
            <span class="tag-pill-count">{tag.articles.length}</span>
          </a>
        </li>
      ))}
    </ul>
  </main>

  <style>
    .tags-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: var(--spacing-06) var(--spacing-05) var(--spacing-10);
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: var(--desktop-caption);
      font-family: var(--monospace);
      color: var(--content-secondary);
      margin-bottom: var(--spacing-06);
    }
    .breadcrumb a { color: var(--content-secondary); text-decoration: none; }
    .breadcrumb a:hover { color: var(--content-primary); }

    .tags-header {
      margin-bottom: var(--spacing-07);
    }
    .tags-header h1 {
      margin: 0 0 var(--spacing-02) 0;
      font-size: clamp(1.5rem, 3vw, 2rem);
    }
    .tags-header p {
      margin: 0;
      font-family: var(--monospace);
      font-size: var(--desktop-body-sm);
      color: var(--content-secondary);
    }

    .tag-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .tag-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: rgba(255, 140, 0, 0.08);
      border: 0.5px solid rgba(255, 140, 0, 0.25);
      color: DarkOrange;
      border-radius: 20px;
      font-size: var(--desktop-body-sm);
      text-decoration: none;
      transition: background 0.15s ease, transform 0.15s ease;
    }
    .tag-pill:hover {
      background: rgba(255, 140, 0, 0.18);
      transform: translateY(-1px);
    }
    .tag-pill-count {
      font-family: var(--monospace);
      font-size: 11px;
      opacity: 0.7;
    }
  </style>
</Layout>
