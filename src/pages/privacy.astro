---
import Layout from "../layouts/Layout.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
const breadcrumbs = [
    { name: "الرئيسية", url: "https://elhellal.com" },
    { name: "سياسة الخصوصية", url: "https://elhellal.com/privacy" },
];
---

<Layout
    site="الهلال"
    title="سياسة الخصوصية"
    tagline="كيف نجمع معلوماتك ونستخدمها ونحميها"
    pageTitle="سياسة الخصوصية"
    pageDescription="اقرأ سياسة خصوصية الهلال لفهم كيفية التعامل مع بياناتك واستخدام ملفات الارتباط وحماية خصوصيتك عند تصفح دليل المقالات العربية."
    canonicalUrl="https://elhellal.com/privacy"
    ogTitle="سياسة الخصوصية — الهلال"
    ogDescription="اقرأ سياسة خصوصية الهلال لفهم كيفية التعامل مع بياناتك وحماية خصوصيتك."
    ogType="website"
    ogUrl="https://elhellal.com/privacy"
    ogSiteName="الهلال"
>
    <BreadcrumbSchema items={breadcrumbs} />

    <main id="main-content" class="container">
        <div class="legal-content-wrapper">
            <header class="legal-header">
                <h1 class="nu-c-h5 nu-u-text--primary">سياسة الخصوصية</h1>
                <p class="last-updated">آخر تحديث: ٤ يناير ٢٠٢٦</p>
            </header>

            <article class="nu-u-text--secondary" itemscope itemtype="https://schema.org/WebPage">
                <p class="nu-c-fs-regular">
                    في <strong class="nu-u-text--primary">الهلال</strong>، المتاح على
                    <a href="https://elhellal.com" class="nu-u-link--subtle">https://elhellal.com</a>،
                    خصوصيتك أولوية. توضح سياسة الخصوصية هذه المعلومات التي نجمعها، وكيف نستخدمها،
                    وحقوقك كزائر لدليل المقالات العربية.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">١. المعلومات التي نجمعها</h2>
                <p>
                    الهلال موقع ثابت. لا يتطلب تسجيل حساب ولا يجمع معلومات تعريف شخصية مباشرةً.
                    البيانات الوحيدة التي نعالجها تأتي من:
                </p>
                <ul>
                    <li><strong class="nu-u-text--primary">بيانات التحليلات</strong> — إحصائيات مجهولة الهوية عبر Google Analytics (الصفحات المزارة، مدة الجلسة، نوع المتصفح، الموقع العام).</li>
                    <li><strong class="nu-u-text--primary">التخزين المحلي</strong> — معرّفات المقالات التي تحفظها، مخزّنة في متصفحك فقط.</li>
                    <li><strong class="nu-u-text--primary">بيانات التواصل</strong> — فقط إذا تواصلت معنا عبر وسائل التواصل الاجتماعي.</li>
                </ul>

                <h2 class="nu-c-h6 nu-u-text--primary">٢. التخزين المحلي والمقالات المحفوظة</h2>
                <p>
                    تستخدم ميزة "المقالات المحفوظة" <strong class="nu-u-text--primary">localStorage</strong>
                    في متصفحك لحفظ المقالات التي تضعها في المفضلة. تبقى هذه البيانات على جهازك تماماً
                    ولا تُرسل إلى خوادمنا. يمكنك حذفها في أي وقت بمسح بيانات المتصفح أو الضغط على "حذف" في الواجهة.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">٣. Google Analytics</h2>
                <p>
                    نستخدم Google Analytics لفهم كيفية تفاعل الزوار مع الهلال.
                    يجمع Google Analytics بيانات مجهولة كالصفحات المزارة والوقت المستغرق ومصادر الإحالة.
                    لا تُشارك معنا أي بيانات شخصية. يمكنك إلغاء الاشتراك بتثبيت
                    <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">إضافة إلغاء اشتراك Google Analytics</a>.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">٤. ملفات الارتباط</h2>
                <p>
                    نستخدم ملفات الارتباط لتحسين تجربة التصفح وتذكّر التفضيلات وتحليل حركة الزيارات.
                    تضع خدمات الطرف الثالث كـ Google Analytics ملفات ارتباطها الخاصة.
                    للتفاصيل الكاملة حول إدارة ملفات الارتباط، راجع
                    <a href="/cookies" class="nu-u-link--subtle">سياسة ملفات الارتباط</a>.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">٥. الإعلانات</h2>
                <p>
                    قد يعرض الهلال إعلانات عبر Google AdSense أو شبكات مماثلة لدعم المشروع.
                    قد تستخدم هذه الشبكات ملفات الارتباط لعرض إعلانات ذات صلة بناءً على سجل تصفحك.
                    يمكنك إدارة تخصيص الإعلانات من خلال
                    <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">إعدادات إعلانات Google</a>.
                    لا نبيع بياناتك الشخصية للمعلنين.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">٦. روابط الطرف الثالث</h2>
                <p>
                    يحتوي دليلنا على روابط لمقالات ومواقع خارجية. لسنا مسؤولين عن ممارسات الخصوصية
                    أو محتوى تلك المواقع. ننصحك بمراجعة سياسات الخصوصية الخاصة بها قبل تقديم أي معلومات شخصية.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">٧. خصوصية الأطفال</h2>
                <p>
                    لا يجمع الهلال معلومات شخصية من الأطفال دون الثالثة عشرة عن قصد.
                    إذا اعتقدت أن طفلاً قدّم معلومات شخصية، يرجى التواصل معنا لحذفها.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">٨. حقوقك</h2>
                <p>
                    وفقاً لموقعك، قد تتمتع بحقوق بموجب GDPR أو CCPA أو أنظمة أخرى،
                    تشمل حق الوصول والتصحيح والحذف. نظراً لمحدودية البيانات التي نجمعها،
                    الإجراء الرئيسي المتاح هو مسح localStorage في متصفحك.
                    للطلبات الأخرى، تواصل معنا أدناه.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">٩. تغييرات على هذه السياسة</h2>
                <p>
                    قد نحدّث سياسة الخصوصية هذه بشكل دوري. ستنعكس التغييرات بتحديث تاريخ "آخر تحديث"
                    في أعلى هذه الصفحة. استمرار استخدامك للهلال بعد التغييرات يُعدّ قبولاً لها.
                </p>

                <h2 class="nu-c-h6 nu-u-text--primary">١٠. تواصل معنا</h2>
                <p>
                    لديك أسئلة حول ممارسات الخصوصية؟ تواصل مع
                    <a href="https://twitter.com/abdou_hll" target="_blank" rel="noopener noreferrer" class="nu-u-link--subtle">@abdou_hll</a>
                    على وسائل التواصل الاجتماعي.
                </p>
            </article>
        </div>
    </main>
</Layout>
