---
import Layout from "../../layouts/Layout.astro";

import "@new-ui/foundations";
import Dashboard from "../../components/Dashboard";
import data from "../../data/articles.json";

export function getStaticPaths() {
  // Derive paths from data instead of hardcoding
  return data.articles.map((cat: any) => ({
    params: { category: cat.category }
  }));
}

const { category } = Astro.params;
---

<Layout
  site={`الهلال - ${category}`}
  title="الهلال"
  tagline="دليل منتقى لأفضل المقالات العربية على الإنترنت"
  pageTitle={`أفضل مقالات ${category} – مقالات منتقاة | الهلال`}
  pageDescription={`استكشف أفضل المقالات العربية في تصنيف ${category} من مختلف المصادر. محتوى عربي عالي الجودة منتقى بعناية.`}
  showSearch={true}
>
  <main id="main-content">
    <Dashboard client:load category={category} />
  </main>
</Layout>

