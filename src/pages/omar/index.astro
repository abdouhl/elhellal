---
import { getCollection } from "astro:content";
import PersonalBlogLayout from "../../layouts/PersonalBlogLayout.astro";
import Header from "../../components/personal-blog/Header.astro";
import Footer from "../../components/personal-blog/Footer.astro";
import PostCard from "../../components/personal-blog/PostCard.astro";
import { personalBlogs } from "../../data/personal-blogs";

const person = personalBlogs.omar;
const posts = (await getCollection("omar")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<PersonalBlogLayout person={person} title={person.nameAr} description={person.bio}>
    <Header person={person} />
    <main class="pb-main">
        <ul class="pb-list">
            {posts.map((post) => (
                <PostCard
                    person={person}
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    slug={post.slug}
                    thumb={post.data.thumb}
                />
            ))}
        </ul>
        {posts.length === 0 && <p class="pb-empty">لا توجد مقالات بعد.</p>}
    </main>
    <Footer person={person} />
</PersonalBlogLayout>

<style>
    .pb-main { max-width: 700px; margin: 0 auto; padding: 1rem 1.5rem 0; }
    .pb-list { list-style: none; margin: 0; padding: 0; }
    .pb-empty { text-align: center; color: #8a857b; padding: 3rem 0; }
</style>
