---
import { type CollectionEntry, getCollection } from "astro:content";
import PersonalBlogLayout from "../../layouts/PersonalBlogLayout.astro";
import Header from "../../components/personal-blog/Header.astro";
import Footer from "../../components/personal-blog/Footer.astro";
import PostCard from "../../components/personal-blog/PostCard.astro";
import { personalBlogs } from "../../data/personal-blogs";

export async function getStaticPaths() {
    const posts = await getCollection("omar");
    return posts.map((post) => ({ params: { slug: post.slug }, props: post }));
}

type Props = CollectionEntry<"omar">;
const post = Astro.props;
const { title, description, pubDate, large } = post.data;
const { Content } = await post.render();
const person = personalBlogs.omar;

const otherPosts = (await getCollection("omar"))
    .filter((p) => p.slug !== post.slug)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

const dateAr = new Intl.DateTimeFormat("ar", { year: "numeric", month: "long", day: "numeric" }).format(pubDate);
---

<PersonalBlogLayout person={person} title={title} description={description} pubDate={pubDate} type="article">
    <Header person={person} />
    <main class="pb-article-main">
        <article class="pb-article">
            <h1 class="pb-h1">{title}</h1>
            <p class="pb-meta">
                <a href={`/${person.slug}`} class="pb-author">{person.nameAr}</a>
                <span> · </span>
                <span>{dateAr}</span>
            </p>
            {large && <img src={large} alt={title} class="pb-cover" />}
            <div class="pb-prose" style={`--accent:${person.accent}`}>
                <Content />
            </div>
        </article>

        {otherPosts.length > 0 && (
            <section class="pb-more">
                <h2 class="pb-more-title">مقالات أخرى</h2>
                <ul class="pb-list">
                    {otherPosts.map((p) => (
                        <PostCard
                            person={person}
                            title={p.data.title}
                            description={p.data.description}
                            pubDate={p.data.pubDate}
                            slug={p.slug}
                            thumb={p.data.thumb}
                        />
                    ))}
                </ul>
            </section>
        )}
    </main>
    <Footer person={person} />
</PersonalBlogLayout>

<style>
    .pb-article-main { max-width: 700px; margin: 0 auto; padding: 1rem 1.5rem 0; }
    .pb-article { padding-bottom: 1rem; border-bottom: 1px solid #d0cdc6; }
    .pb-h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 800; line-height: 1.4; margin: 0 0 0.75rem; color: #1c1b1a; }
    .pb-meta { font-size: 0.85rem; color: #8a857b; margin: 0 0 1.5rem; }
    .pb-author { font-weight: 700; color: #1c1b1a; text-decoration: none; }
    .pb-author:hover { text-decoration: underline; }
    .pb-cover { width: 100%; height: auto; margin-bottom: 1.5rem; }
    .pb-prose { font-size: 1.05rem; line-height: 2; color: #2c2a26; }
    .pb-prose :global(h2) { font-size: 1.3rem; font-weight: 700; margin: 2rem 0 1rem; color: #1c1b1a; }
    .pb-prose :global(p) { margin: 0 0 1.25rem; }
    .pb-prose :global(a) { color: var(--accent); text-decoration: underline; }
    .pb-prose :global(blockquote) { border-inline-start: 3px solid var(--accent); padding-inline-start: 1rem; margin: 1.5rem 0; color: #55524b; }
    .pb-more { margin-top: 2.5rem; }
    .pb-more-title { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #8a857b; margin: 0 0 0.5rem; }
    .pb-list { list-style: none; margin: 0; padding: 0; }
</style>
