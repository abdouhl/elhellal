---
import Layout from "../layouts/Layout.astro";
import FavoritesView from "../components/FavoritesView";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
import { getPersonalBlogFeedArticles } from "../utils/personalBlogFeed";

const breadcrumbs = [
    { name: "الرئيسية", url: "https://elhellal.com" },
    { name: "المقالات المحفوظة" },
];

const personalBlogArticles = await getPersonalBlogFeedArticles();
---

<Layout
    site="الهلال - المقالات المحفوظة"
    title="المقالات المحفوظة"
    tagline="المقالات التي حفظتها للوصول السريع"
    pageTitle="المقالات المحفوظة"
    pageDescription="مجموعة مقالاتك المحفوظة"
    noindex
>
    <BreadcrumbSchema items={breadcrumbs} />
    <main id="main-content">
        <FavoritesView client:load extraArticles={personalBlogArticles} />
    </main>
</Layout>
